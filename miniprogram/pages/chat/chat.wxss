/* pages/chat/chat.wxss */
.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #FAF7F2;
}

/* —— 顶部目的地条 —— */
.dest-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #E1DCD3;
}
.dest-bar-flag { font-size: 44rpx; }
.dest-bar-info { flex: 1; }
.dest-bar-name { font-size: 28rpx; font-weight: 700; color: #2A2723; }
.dest-bar-hint { font-size: 20rpx; color: #8A857F; margin-top: 2rpx; }

.mode-toggle {
  display: flex;
  gap: 4rpx;
  background: #F0EDE6;
  border-radius: 24rpx;
  padding: 4rpx;
}
.mode-btn {
  padding: 8rpx 16rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #8A857F;
  border-radius: 20rpx;
}
.mode-btn.active { background: #0E7C6B; color: #fff; }

/* —— 消息流 —— */
.messages {
  flex: 1;
  padding: 24rpx 24rpx;
  box-sizing: border-box;
}

/* —— 欢迎语 —— */
.welcome {
  padding: 60rpx 20rpx;
  text-align: center;
}
.welcome-emoji { font-size: 80rpx; margin-bottom: 20rpx; }
.welcome-title { font-size: 32rpx; font-weight: 700; color: #2A2723; margin-bottom: 8rpx; }
.welcome-hint { font-size: 24rpx; color: #8A857F; margin-bottom: 40rpx; }
.sugg-list { display: flex; flex-direction: column; gap: 16rpx; }
.sugg-chip {
  background: #fff;
  border: 2rpx solid #E1DCD3;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 26rpx;
  color: #2A2723;
  text-align: left;
}

/* —— 单条消息 —— */
.msg {
  margin-bottom: 24rpx;
  display: flex;
}
.msg.user { justify-content: flex-end; }
.msg.assistant { justify-content: flex-start; }
.msg-bubble {
  max-width: 80%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  position: relative;
}
.msg.user .msg-bubble {
  background: #0E7C6B;
  color: #fff;
  border-bottom-right-radius: 6rpx;
}
.msg.assistant .msg-bubble {
  background: #fff;
  color: #2A2723;
  border-bottom-left-radius: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,.04);
}
.msg-text {
  white-space: pre-wrap;
  word-break: break-word;
}
.msg-search-badge {
  display: inline-block;
  font-size: 20rpx;
  color: #0E7C6B;
  background: #E3F5F1;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  margin-bottom: 10rpx;
}
.msg-mode-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background: #fff;
  border: 2rpx solid #E1DCD3;
  border-radius: 50%;
  width: 36rpx;
  height: 36rpx;
  font-size: 18rpx;
  text-align: center;
  line-height: 32rpx;
}
.msg-mode-badge.fast { color: #E07A12; }
.msg-mode-badge.pro  { color: #0E7C6B; }

/* —— 正在思考动画 —— */
.typing {
  display: flex;
  gap: 8rpx;
  padding: 8rpx 0;
}
.typing .dot {
  width: 12rpx;
  height: 12rpx;
  background: #8A857F;
  border-radius: 50%;
  animation: typing-bounce 1.2s infinite ease-in-out;
}
.typing .dot:nth-child(2) { animation-delay: .2s; }
.typing .dot:nth-child(3) { animation-delay: .4s; }
@keyframes typing-bounce {
  0%, 80%, 100% { opacity: .3; transform: scale(.8); }
  40% { opacity: 1; transform: scale(1); }
}

/* —— 输入区 —— */
.input-area {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #E1DCD3;
}
.input-box {
  flex: 1;
  background: #F0EDE6;
  border-radius: 16rpx;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  max-height: 180rpx;
  min-height: 60rpx;
}
.send-btn {
  background: #0E7C6B;
  color: #fff;
  border-radius: 16rpx;
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  font-weight: 700;
  margin: 0;
  line-height: 1.2;
}
.send-btn[disabled] { background: #C0C0C0 !important; color: #fff !important; }
.send-btn::after { border: none; }
