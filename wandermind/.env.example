# ── MiMo / 小米 ──────────────────────────────────────────────
API_KEY=sk-your-mimo-key-here
CHAT_URL=https://api.xiaomimimo.com/v1/chat/completions
MODEL=mimo-v2.5-pro

# ── 或切换为 Anthropic Claude ───────────────────────────────
# API_KEY=sk-ant-api03-YOUR_ANTHROPIC_KEY
# CHAT_URL=https://api.anthropic.com/v1/messages   ← 注意：需要同步修改 main.py 的解析逻辑
# MODEL=claude-sonnet-4-5

# ── 必填 ─────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-string

# Email verification / password reset (required for production registration)
RESEND_API_KEY=
EMAIL_FROM=WanderMind <noreply@wandermind.cc>

# Google Identity Services OAuth 2.0 Web client ID (optional)
GOOGLE_CLIENT_ID=

# Local testing only. Never enable this in production.
ALLOW_DEV_VERIFICATION_CODE=0
